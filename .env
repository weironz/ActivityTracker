# ========================================
# ActivityTracker 统一配置文件
# ========================================

# ----------------------------------------
# Kafka 配置
# ----------------------------------------
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_TOPIC_PAGE_VIEW=page-view
KAFKA_TOPIC_SEARCH=search
KAFKA_TOPIC_CLICK=click
KAFKA_TOPIC_PURCHASE=purchase
KAFKA_TOPIC_FILTER=user-action
KAFKA_CONSUMER_GROUP_ID=recommendation-engine

# ----------------------------------------
# 前端配置
# ----------------------------------------
FRONTEND_SERVER_NAME=localhost
FRONTEND_PORT=80
BACKEND_HOST=app
BACKEND_PORT=5000

# ----------------------------------------
# 后端配置
# ----------------------------------------
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True
LOG_LEVEL=INFO

# ----------------------------------------
# 推荐系统配置
# ----------------------------------------
RECOMMENDATION_TOP_N=4
RECOMMENDATION_HISTORY_SIZE=5

# ----------------------------------------
# Kafka UI 配置
# ----------------------------------------
KAFBAT_UI_PORT=8080
KAFBAT_UI_ENABLED=true
